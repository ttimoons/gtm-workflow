{
  "name": "gtm-workflow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-projects.js",
    "dev": "vite --host 0.0.0.0 --port 5173",
    "dev:server": "node --env-file=.env.local server.js",
    "gdrive-auth": "node --env-file=.env.local scripts/gdrive-auth.js",
    "start": "vite --host 0.0.0.0 --port 5173",
    "prebuild": "node scripts/sync-projects.js",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "prepreview": "node scripts/sync-projects.js",
    "preview": "vite preview",
    "sync-projects": "node scripts/sync-projects.js",
    "postinstall": "node scripts/sync-projects.js",
    "start:prod": "npm run build && node --env-file=.env server.js"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.0",
    "googleapis": "^144.0.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
