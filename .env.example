# ── Google Drive backup (server.js) ─────────────────────────────
# Run `node scripts/gdrive-auth.js` once locally to populate these.
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=
GDRIVE_FOLDER_ID=

# ── Google sign-in (server.js) ──────────────────────────────────
# Same OAuth client can be reused. Generate AUTH_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUTH_REDIRECT_URI must exactly match a redirect URI whitelisted in
# Google Cloud Console, e.g.
#   http://localhost:3000/api/auth/google/callback     (local prod testing)
#   https://your-app.example.com/api/auth/google/callback   (deployed)
AUTH_SECRET=
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_REDIRECT_URI=
