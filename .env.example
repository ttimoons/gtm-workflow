# ── Google sign-in (server.js — self-hosted only) ───────────────
# Generate AUTH_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUTH_REDIRECT_URI must exactly match a redirect URI whitelisted in
# Google Cloud Console, e.g.
#   http://localhost:3000/api/auth/google/callback     (local prod testing)
#   https://your-app.example.com/api/auth/google/callback   (deployed)
AUTH_SECRET=
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_REDIRECT_URI=

# ── Client-side OAuth (Vite build-time) ─────────────────────────
# Same Google OAuth Client ID — used by the browser via Google Identity Services.
# This is the ONLY env var needed for static deployments (Netlify, Vercel, etc.).
VITE_GOOGLE_CLIENT_ID=
